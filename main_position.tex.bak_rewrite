        deepseek vs.\ mimo-v2 & 708 & 87.9\% & 0.755 \\
        deepseek vs.\ llama-3.3 & 682 & 87.5\% & 0.746 \\
        llama-3.3 vs.\ qwen3.5 & 467 & 86.9\% & 0.723 \\
        \midrule
        \textbf{Mean (all pairs)} & --- & \textbf{88.1\%} & \textbf{0.756} \\
        \bottomrule
    \end{tabular}
\end{table}


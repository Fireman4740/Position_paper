@inproceedings{dundar_performance_2025-1,
	title = {Performance {Analysis} of {Text} {Chunking} {Methods} for {LLM}-{Based} {Document} {Summarization}},
	issn = {2521-1641},
	url = {https://ieeexplore.ieee.org/document/11206896},
	doi = {10.1109/UBMK67458.2025.11206896},
	abstract = {The limited context window of Large Language Models (LLMS) presents a challenge for long-document summarization, requiring documents to be chunked into smaller segments. This paper evaluates four chunking strategies—Fixed-Length, Recursive, Sliding Window, and Semantic Chunking—across two leading LLMS: Llama 3.1 8B Instruct (meta-llama/Meta-Llama-3.1-8B-Instruct) and Phi-4-mini Instruct (microsoft/Phi-4-mini-instruct), using two real-world datasets: ccdv/govreport-summarization and dreamproit/bill\_summary\_us. Across both models and datasets, Recursive chunking consistently underperforms. Sliding Window achieves the best results on ccdv/govreport-summarization with Llama 3.1, improving ROUGE-1 and BLEU by up to 22.7\% and 55.0\% over Recursive. Semantic chunking performs best on dreamproit/bill\_summary\_us and with Phi-4-mini on govreport-summarization, though it lags slightly in efficiency. All methods show negligible runtime cost, but Fixed-Length and Sliding Window offer better scalability and ease of use. These findings highlight that simpler chunking approaches with overlapping context can be highly effective for LLM-based summarization pipelines in domains like government and legal documents.},
	urldate = {2025-12-16},
	booktitle = {2025 10th {International} {Conference} on {Computer} {Science} and {Engineering} ({UBMK})},
	author = {Dündar, Salih and Şahin, Öykü and Özer, Mehmet Ali},
	month = sep,
	year = {2025},
	keywords = {Chunking Methods, Computational modeling, Large Language Models, Large language models, Long-Document Processing, Performance analysis, Pipelines, Question answering (information retrieval), Retrieval augmented generation, Runtime, Scalability, Semantics, Text Summarization, Text summarization},
	pages = {605--609},
}

@misc{chen_menli_2023,
	title = {{MENLI}: {Robust} {Evaluation} {Metrics} from {Natural} {Language} {Inference}},
	shorttitle = {{MENLI}},
	url = {http://arxiv.org/abs/2208.07316},
	doi = {10.48550/arXiv.2208.07316},
	abstract = {Recently proposed BERT-based evaluation metrics for text generation perform well on standard benchmarks but are vulnerable to adversarial attacks, e.g., relating to information correctness. We argue that this stems (in part) from the fact that they are models of semantic similarity. In contrast, we develop evaluation metrics based on Natural Language Inference (NLI), which we deem a more appropriate modeling. We design a preference-based adversarial attack framework and show that our NLI based metrics are much more robust to the attacks than the recent BERT-based metrics. On standard benchmarks, our NLI based metrics outperform existing summarization metrics, but perform below SOTA MT metrics. However, when combining existing metrics with our NLI metrics, we obtain both higher adversarial robustness (15\%-30\%) and higher quality metrics as measured on standard benchmarks (+5\% to 30\%).},
	urldate = {2025-08-29},
	publisher = {arXiv},
	author = {Chen, Yanran and Eger, Steffen},
	month = dec,
	year = {2023},
	note = {arXiv:2208.07316 [cs]},
	keywords = {Computer Science - Computation and Language, Computer Science - Cryptography and Security, Computer Science - Machine Learning},
}

